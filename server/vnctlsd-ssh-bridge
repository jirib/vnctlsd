#!/usr/bin/env python3
"""
vnctlsd SSH access command.

Install on the server in a PATH-visible location (e.g. /usr/bin/) so that
users can reach vnctlsd consoles over SSH without any sshd_config changes:

    ssh <host> vnctlsd-ssh-bridge

sshd authenticates the user (key, password, MFA — whatever the site policy
requires) and executes this command as that user.  The command's only job is
to connect to vnctlsd's Unix socket and pipe stdin/stdout through it.

Identity is established entirely by the kernel: the daemon reads SO_PEERCRED
on the accepted connection and sees this process's uid.  Because sshd drops
privileges to the authenticated user before exec'ing the command, that uid is
the authenticated user's uid.  No credential or claim is sent by this command
— none would be trusted anyway.
"""
import argparse
import os
import pwd
import select
import socket
import stat
import sys

_DEFAULT_SOCKET = "/run/vnctlsd/vnctlsd.sock"
_BUFSIZE = 65536


def _check_socket(path: str) -> str | None:
    """
    Validate that path is a legitimately created daemon socket.

    Uses lstat so symlinks are rejected before they can redirect the
    connection.  Returns an error string on any problem, None if OK.
    """
    try:
        dir_st = os.lstat(os.path.dirname(path) or ".")
    except OSError as exc:
        return f"cannot stat parent directory: {exc}"
    if dir_st.st_mode & stat.S_IWOTH:
        return "parent directory is world-writable"

    try:
        st = os.lstat(path)
    except FileNotFoundError:
        return "daemon not running or socket not configured"
    except OSError as exc:
        return str(exc)

    if stat.S_ISLNK(st.st_mode):
        return "is a symlink"
    if not stat.S_ISSOCK(st.st_mode):
        return "not a socket"
    try:
        daemon_uid = pwd.getpwnam('_vnctlsd').pw_uid
    except KeyError:
        return "daemon account '_vnctlsd' not found on this system"
    if st.st_uid != daemon_uid:
        return f"not owned by _vnctlsd (owner uid={st.st_uid})"

    return None


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="vnctlsd-ssh-bridge",
        description="vnctlsd SSH access command")
    parser.add_argument(
        "--socket", default=_DEFAULT_SOCKET, metavar="PATH",
        help=f"vnctlsd socket path (default: {_DEFAULT_SOCKET})")
    args = parser.parse_args()

    err = _check_socket(args.socket)
    if err is not None:
        sys.stderr.write(f"vnctlsd: {args.socket}: {err}\n")
        sys.exit(1)

    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.connect(args.socket)
    except PermissionError:
        sys.stderr.write(f"vnctlsd: {args.socket}: permission denied\n")
        sys.exit(1)
    except OSError as exc:
        sys.stderr.write(f"vnctlsd: cannot connect to {args.socket}: {exc}\n")
        sys.exit(1)

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()
    sock_fd = sock.fileno()

    try:
        while True:
            try:
                readable, _, _ = select.select([stdin_fd, sock_fd], [], [])
            except (KeyboardInterrupt, InterruptedError):
                break

            if sock_fd in readable:
                data = os.read(sock_fd, _BUFSIZE)
                if not data:
                    break
                os.write(stdout_fd, data)

            if stdin_fd in readable:
                data = os.read(stdin_fd, _BUFSIZE)
                if not data:
                    break
                sock.sendall(data)
    finally:
        try:
            sock.shutdown(socket.SHUT_RDWR)
        except OSError:
            pass
        sock.close()


if __name__ == "__main__":
    main()
